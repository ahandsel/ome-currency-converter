{
  "name": "ome-currency-converter",
  "version": "0.1.0",
  "private": false,
  "description": "A web app that generates an iPhone wallpaper showing live currency exchange rates.",
  "keywords": [
    "currency-converter",
    "exchange-rates",
    "wallpaper",
    "iphone",
    "canvas",
    "travel",
    "frankfurter"
  ],
  "homepage": "https://github.com/ahandsel/ome-currency-converter#readme",
  "bugs": {
    "url": "https://github.com/ahandsel/ome-currency-converter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahandsel/ome-currency-converter.git"
  },
  "license": "MIT",
  "author": "ahandsel",
  "type": "module",
  "scripts": {
    "ai-claude": "claude",
    "ai-cursor": "agent",
    "build": "nuxt build",
    "check-license": "license-manager analyze --config license-manager.config.cjs",
    "cleanup": "zsh ./scripts/cleanup-temp-files.sh",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "index": "zsh scripts/index.sh",
    "lint": "pnpm run lint-code && pnpm run lint-md",
    "lint-code": "prettier --write .",
    "lint-md": "markdownlint-cli2 --fix",
    "preview": "nuxt preview",
    "test": "pnpm run lint && pnpm run test-names && pnpm run check-license && pnpm run test-unit",
    "test-names": "node skills/file-folder-name-linter/scripts/lint-names.mjs",
    "test-unit": "vitest run"
  },
  "dependencies": {
    "@nuxt/icon": "^2.3.1",
    "nuxt": "^4.4.8",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@cybozu/license-manager": "1.4.1",
    "@iconify-json/material-symbols": "^1.2.83",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/i18n": "^10.4.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@vue/test-utils": "^2.4.11",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "happy-dom": "^20.10.6",
    "markdownlint-cli2": "^0.23.0",
    "markdownlint-rule-relative-links": "^5.1.1",
    "markdownlint-rule-search-replace": "^1.2.0",
    "prettier": "^3.9.5",
    "prettier-plugin-autocorrect": "^0.4.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sh": "^0.19.0",
    "prettier-plugin-sql": "^0.20.0",
    "prettier-plugin-toml": "^2.0.6",
    "sh-syntax": "^0.6.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
