// https://github.com/DavidAnson/markdownlint-cli2

{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",

  // Base markdownlint rule config
  "config": {
    "blanks-around-fences": true,
    "MD004": { "style": "asterisk" },
    "MD007": { "indent": 2 },
    "MD009": { "br_spaces": 2 },
    "MD012": { "maximum": 2 },
    "MD013": false,
    "MD014": false,
    "MD022": { "lines_above": 2, "lines_below": 1 },
    "MD024": false,
    "MD025": { "front_matter_title": "{{$frontmatter.title}}" },
    "MD026": false,
    "MD029": { "style": "ordered" },
    "MD032": false,
    "MD033": {
      "allowed_elements": ["br", "pre", "script", "ul", "li", "ol", "RepoCards"],
    },
    "MD036": false,
    "search-replace": {
      "rules": [
        {
          "name": "curly-double-quotes",
          "message": "Do not use curly double quotes.",
          "searchPattern": "/“|”/g",
          "replace": "\"",
        },
        {
          "name": "curly-single-quotes",
          "message": "Do not use curly single quotes.",
          "searchPattern": "/‘|’/g",
          "replace": "'",
        },
        {
          "name": "em-dash",
          "message": "Do not use em dashes.",
          "searchPattern": "/—/g",
          "replace": "-",
        },
        {
          "name": "en-dash",
          "message": "Do not use en dashes. Use a hyphen instead.",
          "searchPattern": "/–/g",
          "replace": "-",
        },
        {
          "name": "non-breaking-space",
          "message": "Do not use non-breaking spaces. Use a regular space instead.",
          "searchPattern": "/ /g",
          "replace": " ",
        },
        {
          "name": "object-replacement-character",
          "message": "Do not use the object replacement character. Use a regular space instead.",
          "searchPattern": "/￼/g",
          "replace": " ",
        },
      ],
    },
  },
  "customRules": [
    "markdownlint-rule-search-replace",
    "markdownlint-rule-relative-links",
  ],

  // Files to lint
  "gitignore": true,
  "globs": ["**/*.md"],

  // Vendored content from upstream plugins/repos - keep pristine for re-sync.
  // Covers both the canonical copy under skills/ and the auto-mirrored copy under .claude/skills/.
  "ignores": [
    // All figma-* skills are vendored from the official Figma plugin.
    "**/skills/figma-*/**",
  ],

  // Optional CLI behavior
  "fix": true,
  "noProgress": true,
  "showFound": true,
}
